# 数据库配置
DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=hotel_db
DB_PORT=5432
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Shanghai

# JWT签名密钥
JWT_SECRET=openssl rand -hex 32

# 腾讯云密钥
COS_BUCKET_URL=
SECRETID=AKIDxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SECRETKEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 腾讯云 COS 存储桶 URL（在 COS 控制台存储桶概览页查看）
COS_BUCKET_URL=https://<bucket>-<appid>.cos.<region>.myqcloud.com